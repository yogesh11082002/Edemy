/**
 * @fileoverview Firestore Security Rules for LearnVerse LMS.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, logins, and signup data,
 * with an additional mechanism for granting admin privileges via the `/roles_admin/{userId}` collection.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/logins/{loginId}: Stores login information for each user.
 * - /users/{userId}/signups/{signupId}: Stores signup information for each user.
 * - /roles_admin/{userId}: Presence of a document grants admin privileges to the user.
 *
 * Key Security Decisions:
 * - User data is strictly controlled by the owning user.
 * - Listing of users is generally disallowed to prevent information disclosure.
 * - Admin privileges are granted by the presence of a document in the `/roles_admin` collection.
 *
 * Denormalization for Authorization:
 * - The existence of a document in `/roles_admin/{userId}` grants admin privileges.
 *   This avoids the need for complex queries or separate role collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants access to user profile information, ensuring only the user can read and write their own data.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user123' can create their own profile at /users/user123 if the document.id matches their UID.
     * @allow (get, update, delete) - User with UID 'user123' can get, update, and delete their own profile at /users/user123.
     * @deny (create) - User with UID 'user456' cannot create a profile at /users/user123.
     * @deny (update, delete) - User with UID 'user456' cannot update or delete the profile at /users/user123.
     * @principle Enforces document ownership for writes and restricts read access to the owner. Validates that the `id` field matches the `userId` in the path.
     */
    match /users/{userId} {
      // Allow anyone to create a user if the userId matches the authenticated user's ID.
      allow create: if isSignedIn() && request.auth.uid == userId && request.resource.data.id == userId;
      // Allow read access if the user is signed in and the userId matches the authenticated user's ID.
      allow get: if isSignedIn() && isOwner(userId);
      // Allow update if the user is signed in, the userId matches the authenticated user's ID, and the document exists.
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      // Allow delete if the user is signed in, the userId matches the authenticated user's ID, and the document exists.
      allow delete: if isSignedIn() && isExistingOwner(userId);
      // Prevent listing of all users.
      allow list: if false;
    }

    /**
     * @description Grants access to user login information, ensuring only the user can read and write their own login data.
     * @path /users/{userId}/logins/{loginId}
     * @allow (create) - User with UID 'user123' can create their login entry at /users/user123/logins/login123.
     * @allow (get, update, delete) - User with UID 'user123' can get, update, and delete their login entry at /users/user123/logins/login123.
     * @deny (create) - User with UID 'user456' cannot create a login entry at /users/user123/logins/login123.
     * @deny (update, delete) - User with UID 'user456' cannot update or delete the login entry at /users/user123/logins/login123.
     * @principle Enforces document ownership for writes and restricts read access to the owner.
     */
    match /users/{userId}/logins/{loginId} {
      // Allow create if the user is signed in and the userId matches the authenticated user's ID.
      allow create: if isSignedIn() && isOwner(userId);
      // Allow read access if the user is signed in and the userId matches the authenticated user's ID.
      allow get: if isSignedIn() && isOwner(userId);
      // Allow update if the user is signed in, the userId matches the authenticated user's ID, and the document exists.
      allow update: if isSignedIn() && isExistingOwner(userId);
      // Allow delete if the user is signed in, the userId matches the authenticated user's ID, and the document exists.
      allow delete: if isSignedIn() && isExistingOwner(userId);
      // Allow the owner to list their own logins.
      allow list: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Grants access to user signup information, ensuring only the user can read and write their own signup data.
     * @path /users/{userId}/signups/{signupId}
     * @allow (create) - User with UID 'user123' can create their signup entry at /users/user123/signups/signup123.
     * @allow (get, update, delete) - User with UID 'user123' can get, update, and delete their signup entry at /users/user123/signups/signup123.
     * @deny (create) - User with UID 'user456' cannot create a signup entry at /users/user123/signups/signup123.
     * @deny (update, delete) - User with UID 'user456' cannot update or delete the signup entry at /users/user123/signups/signup123.
     * @principle Enforces document ownership for writes and restricts read access to the owner.
     */
    match /users/{userId}/signups/{signupId} {
      // Allow create if the user is signed in and the userId matches the authenticated user's ID.
      allow create: if isSignedIn() && isOwner(userId);
      // Allow read access if the user is signed in and the userId matches the authenticated user's ID.
      allow get: if isSignedIn() && isOwner(userId);
      // Allow update if the user is signed in, the userId matches the authenticated user's ID, and the document exists.
      allow update: if isSignedIn() && isExistingOwner(userId);
      // Allow delete if the user is signed in, the userId matches the authenticated user's ID, and the document exists.
      allow delete: if isSignedIn() && isExistingOwner(userId);
      // Allow the owner to list their own signups.
      allow list: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Grants read access to admin role documents, allowing admin role verification. Writes are disallowed.
     * @path /roles_admin/{userId}
     * @allow (get) - User with UID 'user123' can check if they have admin privileges by reading /roles_admin/user123.
     * @deny (create, update, delete) - No one can create, update, or delete documents in /roles_admin.
     * @principle Restricts write access to prevent unauthorized role assignment.
     */
    match /roles_admin/{userId} {
      // Allow read access to check for admin privileges if the user is signed in.
      allow get: if isSignedIn();
      // Prevent creation of admin role documents.
      allow create: if false;
      // Prevent updates to admin role documents.
      allow update: if false;
      // Prevent deletion of admin role documents.
      allow delete: if false;
      // Prevent listing of admin role documents.
      allow list: if false;
    }
  }

  // Helper function to determine if the user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }

  // Helper function to determine if the user is the owner of the document.
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

    // Helper function to determine if the user is the existing owner of the document.
  function isExistingOwner(userId) {
    return isSignedIn() && isOwner(userId) && resource != null;
  }
}