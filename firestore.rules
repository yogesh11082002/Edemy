/**
 * @fileoverview Firestore Security Rules for LearnVerse LMS.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, logins, and signup data,
 * with an additional role-based access control mechanism for administrative functions.
 * Authorization Independence is achieved by denormalizing role data and using path-based access control.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, secured by owner-only access.
 * - /users/{userId}/logins/{loginId}: Stores login information, secured by owner-only access.
 * - /users/{userId}/signups/{signupId}: Stores signup information, secured by owner-only access.
 * - /roles_admin/{userId}: Stores admin role indicators; presence of a document grants admin privileges.
 *
 * Key Security Decisions:
 * - User data is strictly controlled by the user; no listing of user documents is allowed to prevent information leakage.
 * - Admin privileges are granted based on the existence of a document in the `/roles_admin` collection, simplifying the admin check.
 * - The rules explicitly deny any ambiguous access, defaulting to the most secure interpretation.
 * - Enforces immutable ownerId in subcollections on update.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces owner-only access to user profile information.
     * @path /users/{userId}
     * @allow (create) - Authenticated user with UID matching the userId in the path can create their own profile.
     * @allow (get, update, delete) - Authenticated user with UID matching the userId in the path can read, update, or delete their profile.
     * @deny (create) - Authenticated user attempts to create a profile with a userId that does not match their own UID.
     * @deny (list) - Prevents listing of all user documents.
     * @deny (update, delete) - Non-authenticated user attempts to update or delete a user profile.
     * @principle Enforces document ownership for writes and restricts access to a user's own data.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces owner-only access to user login information.
     * @path /users/{userId}/logins/{loginId}
     * @allow (create) - Authenticated user with UID matching the userId in the path can create login information. Requires `userId` in data matching the path.
     * @allow (get, update, delete) - Authenticated user with UID matching the userId in the path can read, update, or delete login information.
     * @deny (create) - Authenticated user attempts to create login information with a userId that does not match their own UID.
     * @deny (list) - Prevents listing of all login documents.
     * @deny (update, delete) - Non-authenticated user attempts to update or delete login information.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId}/logins/{loginId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces owner-only access to user signup information.
     * @path /users/{userId}/signups/{signupId}
     * @allow (create) - Authenticated user with UID matching the userId in the path can create signup information. Requires `userId` in data matching the path.
     * @allow (get, update, delete) - Authenticated user with UID matching the userId in the path can read, update, or delete signup information.
     * @deny (create) - Authenticated user attempts to create signup information with a userId that does not match their own UID.
     * @deny (list) - Prevents listing of all signup documents.
     * @deny (update, delete) - Non-authenticated user attempts to update or delete signup information.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId}/signups/{signupId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Grants read access to admin role documents based on user ID, effectively allowing admin role checking.
     * @path /roles_admin/{userId}
     * @allow (get) - Authenticated user with UID matching the userId in the path can read the admin role document.
     * @deny (list) - Prevents listing of all admin role documents.
     * @deny (create, update, delete) - Only server-side functions or authorized personnel can create, update, or delete admin role documents.
     * @principle Supports role-based access control using document existence as an indicator.
     */
    match /roles_admin/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}