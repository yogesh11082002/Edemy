/**
 * @fileoverview Firestore Security Rules for LearnVerse LMS.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, logins, and signup data,
 * combined with role-based access control for administrative functions. It leverages structural
 * segregation to ensure consistent security within collections and authorization independence
 * to avoid costly `get()` operations.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information; owner-only access.
 * - /users/{userId}/logins/{loginId}: Stores user login information; owner-only access.
 * - /users/{userId}/signups/{signupId}: Stores user signup information; owner-only access.
 * - /roles_admin/{userId}: Indicates admin privileges; only accessible to admins.
 *
 * Key Security Decisions:
 * - User listing is disallowed for privacy.
 * - Write operations are strictly controlled based on ownership and role.
 * - The rules are designed to be auditable and maintainable through the use of helper functions.
 * - Authorization Independence: User roles are checked directly via the /roles_admin collection to avoid `get()` calls.
 *
 * Denormalization for Authorization:
 * The existence of a document in `/roles_admin/{userId}` is used as the source of truth for admin privileges.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by a signed-in user.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the request is made by the owner of the resource.
     * @param {string} userId - The user ID to check against.
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the document exists and the request is made by the owner.
     * @param {string} userId - The user ID to check against.
     * @return {bool} True if the user is the owner and the resource exists.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Checks if the user is an admin by verifying the existence of their document under the /roles_admin collection.
     * @return {bool} True if the user is an admin, false otherwise.
     */
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Defines paths for /users/{userId} documents.
     * @path /databases/{database}/documents/users/{userId}
     * @allow (create) User 'm0485uyCOuX7l87QAypT4sD6rr22' can create their own user document.
     * @deny (create) User 'randomId' cannot create a user document with userId = 'm0485uyCOuX7l87QAypT4sD6rr22'.
     * @allow (get) User 'm0485uyCOuX7l87QAypT4sD6rr22' can get their user document.
     * @deny (get) User 'randomId' cannot get User 'm0485uyCOuX7l87QAypT4sD6rr22' document.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // User listing is disallowed for privacy.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Defines paths for /users/{userId}/logins/{loginId} documents.
     * @path /databases/{database}/documents/users/{userId}/logins/{loginId}
     * @allow (create) User 'm0485uyCOuX7l87QAypT4sD6rr22' can create a login document under their user document.
     * @deny (create) User 'randomId' cannot create a login document under User 'm0485uyCOuX7l87QAypT4sD6rr22'.
     * @allow (get) User 'm0485uyCOuX7l87QAypT4sD6rr22' can get a login document under their user document.
     * @deny (get) User 'randomId' cannot get a login document under User 'm0485uyCOuX7l87QAypT4sD6rr22'.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId}/logins/{loginId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Defines paths for /users/{userId}/signups/{signupId} documents.
     * @path /databases/{database}/documents/users/{userId}/signups/{signupId}
     * @allow (create) User 'm0485uyCOuX7l87QAypT4sD6rr22' can create a signup document under their user document.
     * @deny (create) User 'randomId' cannot create a signup document under User 'm0485uyCOuX7l87QAypT4sD6rr22'.
     * @allow (get) User 'm0485uyCOuX7l87QAypT4sD6rr22' can get a signup document under their user document.
     * @deny (get) User 'randomId' cannot get a signup document under User 'm0485uyCOuX7l87QAypT4sD6rr22'.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId}/signups/{signupId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Defines paths for /roles_admin/{userId} documents.  The existence of this document confers admin rights.
     * @path /databases/{database}/documents/roles_admin/{userId}
     * @allow (get) Admin can access the document to confirm their admin rights.
     * @deny (get) Non-Admin cannot access the document.
     * @allow (create) Only an existing admin can create a new admin role document.
     * @deny (create) Regular user cannot create a new admin role document.
     *
     * @principle This collection controls admin privileges by verifying the user's existance in the collection.
     */
    match /roles_admin/{userId} {
      allow get: if isAdmin();
      allow list: if false; // Listing not needed, existence check is sufficient.
      allow create: if isAdmin();
      allow update: if false; // Admin role modification not permitted for now.
      allow delete: if isAdmin();
    }
  }
}