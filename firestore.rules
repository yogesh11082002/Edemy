/**
 * @fileoverview Firestore Security Rules for LearnVerse LMS.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, logins, and signup data,
 * with additional role-based access control for admin users.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information. Each user can only manage their own profile.
 * - /users/{userId}/logins/{loginId}: Stores login information for each user. Only the user can access their own login data.
 * - /users/{userId}/signups/{signupId}: Stores signup information for each user. Only the user can access their own signup data.
 * - /roles_admin/{userId}: Stores admin role information. Only admins can manage this collection.
 *
 * Key Security Decisions:
 * - Users can only create, read, update, and delete their own user profile, login, and signup data.
 * - Listing of user documents is allowed only for admins.
 * - Admin privileges are determined by the existence of a document in the /roles_admin/{userId} collection.
 *
 * Denormalization for Authorization:
 * The `role` field within the `/users/{userId}` document is denormalized to avoid needing to fetch role information
 * from a separate document when enforcing security rules on user data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their own profile.
     * @allow (get) User with ID 'user123' can read their own profile.
     * @allow (update) User with ID 'user123' can update their own profile.
     * @allow (delete) User with ID 'user123' can delete their own profile.
     * @deny (create) User with ID 'user123' cannot create a profile for user 'user456'.
     * @deny (get) User with ID 'user123' cannot read the profile of user 'user456' unless they are an admin.
     * @principle Enforces document ownership and admin role for user profiles.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to user login documents.
     * @path /users/{userId}/logins/{loginId}
     * @allow (create) User with ID 'user123' can create their own login entry.
     * @allow (get) User with ID 'user123' can read their own login entry.
     * @allow (update) User with ID 'user123' can update their own login entry.
     * @allow (delete) User with ID 'user123' can delete their own login entry.
     * @deny (create) User with ID 'user123' cannot create a login entry for user 'user456'.
     * @deny (get) User with ID 'user123' cannot read the login entry of user 'user456'.
     * @principle Enforces document ownership for user login data.
     */
    match /users/{userId}/logins/{loginId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to user signup documents.
     * @path /users/{userId}/signups/{signupId}
     * @allow (create) User with ID 'user123' can create their own signup entry.
     * @allow (get) User with ID 'user123' can read their own signup entry.
     * @allow (update) User with ID 'user123' can update their own signup entry.
     * @allow (delete) User with ID 'user123' can delete their own signup entry.
     * @deny (create) User with ID 'user123' cannot create a signup entry for user 'user456'.
     * @deny (get) User with ID 'user123' cannot read the signup entry of user 'user456'.
     * @principle Enforces document ownership for user signup data.
     */
    match /users/{userId}/signups/{signupId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to admin role documents.
     * @path /roles_admin/{userId}
     * @allow (create) Admin user with ID 'admin123' can create their admin role document.
     * @allow (get) Any user can check if 'admin123' has admin role.
     * @allow (update) Admin user with ID 'admin123' can update their admin role document.
     * @allow (delete) Admin user with ID 'admin123' can delete their admin role document.
     * @deny (create) Non-admin user with ID 'user123' cannot create an admin role document.
     * @deny (update) Non-admin user with ID 'user123' cannot update an admin role document.
     * @principle Restricts management of admin roles to existing admins.
     */
    match /roles_admin/{userId} {
      allow get: if isAdmin();
      allow list: if false;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
  }
}