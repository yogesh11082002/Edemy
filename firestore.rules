/**
 * @fileoverview Firestore Security Rules for LearnVerse LMS.
 *
 * Core Philosophy: This ruleset enforces a strict user-ownership model for user profiles and related data,
 * and uses a dedicated collection to manage admin roles. Authorization Independence is achieved by
 * avoiding hierarchical `get()` calls in security rules, using path-based ownership and denormalized data.
 * Rules are not filters are supported through structural segregation.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, secured by owner-only access.
 * - /users/{userId}/logins/{loginId}: Stores login information, secured by owner-only access.
 * - /users/{userId}/signups/{signupId}: Stores signup information, secured by owner-only access.
 * - /roles_admin/{userId}: Existence of a document grants admin privileges.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Admin roles are managed via document existence in the `/roles_admin` collection.
 * - Strict owner-only access is enforced for all data under `/users/{userId}`.
 * - Validation will focus on authorization fields and path consistency, omitting detailed schema validation for rapid prototyping.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages user profile information.
     * @path /users/{userId}
     * @allow (create) Authenticated user can create their own profile if the userId matches their auth.uid.
     * @allow (get, update, delete) Authenticated user can get, update and delete their own profile if the userId matches their auth.uid.
     * @deny (create) An unauthenticated user cannot create a user profile.
     * @deny (update, delete) A different authenticated user cannot update or delete this profile.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages user login information.
     * @path /users/{userId}/logins/{loginId}
     * @allow (create) Authenticated user can create login information under their own profile.
     * @allow (get, update, delete) Authenticated user can get, update, and delete login information under their own profile.
     * @deny (create) An unauthenticated user cannot create login information.
     * @deny (update, delete) A different authenticated user cannot update or delete this login information.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId}/logins/{loginId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages user signup information.
     * @path /users/{userId}/signups/{signupId}
     * @allow (create) Authenticated user can create signup information under their own profile.
     * @allow (get, update, delete) Authenticated user can get, update and delete signup information under their own profile.
     * @deny (create) An unauthenticated user cannot create signup information.
     * @deny (update, delete) A different authenticated user cannot update or delete this signup information.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId}/signups/{signupId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages admin roles. Document existence grants admin privileges.
     * @path /roles_admin/{userId}
     * @allow (create) Only an existing user can be granted admin role.
     * @allow (get) Any authenticated user can check if a user is an admin.
     * @allow (delete) Only an existing admin can revoke another user's admin role.
     * @deny (list, update) Listing and updating this collection is not allowed.
     * @principle Enforces admin role management via document existence.
     */
    match /roles_admin/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // Check if the requesting user is an admin by verifying the existence of their document in /roles_admin/{request.auth.uid}
      function isAdmin() {
          return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && isAdmin();
      allow update: if false;
      allow delete: if isSignedIn() && isAdmin();
    }
  }
}