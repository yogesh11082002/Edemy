/**
 * @fileoverview Firestore Security Rules for LearnVerse LMS.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, logins, and signup data,
 * with administrative privileges controlled by the presence of a document in the `/roles_admin` collection.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information.
 * - /users/{userId}/logins/{loginId}: Stores login information for a user.
 * - /users/{userId}/signups/{signupId}: Stores signup information for a user.
 * - /roles_admin/{userId}: Presence of a document grants admin privileges.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profile data and associated login/signup information.
 * - Only users with a document in `/roles_admin/{userId}` can perform admin-level operations (not yet defined in these rules).
 * - Listing of users is generally disallowed to prevent information disclosure.
 *
 * Denormalization for Authorization:
 * - User roles are stored directly in the `/users/{userId}` document to avoid costly `get()` calls when checking for admin privileges.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure user profile information.
     * @path /users/{userId}
     * @allow (create) - User with matching UID can create their own profile.
     * @allow (get, update, delete) - User can access and modify their own profile.
     * @deny (create) - User cannot create a profile with a mismatched UID.
     * @deny (get, update, delete) - User cannot access or modify another user's profile.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      function isExistingOwner(userId) {
          return isOwner(userId) && existsAfter(/databases/$(database)/documents/users/$(userId));
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secure user login information.
     * @path /users/{userId}/logins/{loginId}
     * @allow (create, get, update, delete, list) - User can manage their own login information.
     * @deny (create, get, update, delete, list) - User cannot access or modify another user's login information.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/logins/{loginId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
        function isSignedIn() {
        return request.auth != null;
      }
       function isExistingOwner(userId) {
          return isOwner(userId) && existsAfter(/databases/$(database)/documents/users/$(userId)/logins/$(loginId));
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secure user signup information.
     * @path /users/{userId}/signups/{signupId}
     * @allow (create, get, update, delete, list) - User can manage their own signup information.
     * @deny (create, get, update, delete, list) - User cannot access or modify another user's signup information.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/signups/{signupId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
        function isSignedIn() {
        return request.auth != null;
      }
       function isExistingOwner(userId) {
          return isOwner(userId) && existsAfter(/databases/$(database)/documents/users/$(userId)/signups/$(signupId));
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to admin roles. Presence of a document grants admin privileges.
     * @path /roles_admin/{userId}
     * @allow (create) - Only a privileged process (e.g., a Cloud Function) can assign admin roles.
     * @allow (get) - Any authenticated user can check if they have admin privileges.
     * @deny (list, update, delete) - Listing, updating, or deleting admin roles is disallowed through security rules.
     * @principle Role-based access control.
     */
    match /roles_admin/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn();
      allow list: if false;
      allow create: if false; // Only assign via a trusted environment
      allow update: if false;
      allow delete: if false;
    }
  }
}