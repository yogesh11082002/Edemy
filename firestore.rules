/**
 * @fileoverview Firestore Security Rules for LearnVerse LMS.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, logins, and signup data.
 * Administrative privileges are managed through a separate `roles_admin` collection.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, with userId matching the authenticated user's UID.
 * - /users/{userId}/logins/{loginId}: Stores login history for each user, with owner-only access.
 * - /users/{userId}/signups/{signupId}: Stores signup information for each user, with owner-only access.
 * - /roles_admin/{userId}: Presence of a document grants admin privileges to the specified user.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect user privacy.
 * - All write operations require a verified, authenticated user.
 * - Authorization Independence is achieved by relating the id of user resources to the request id.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Requires a verified, authenticated user for all operations.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided userId.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Enforces document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is an existing owner of the resource
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Enforces that the resource exists before the rule can use it.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Checks if the authenticated user has admin privileges.
     * @path N/A
     * @allow N/A
     * @deny N/A
     * @principle Checks the roles_admin collection for admin privileges.
     */
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Rules for user profiles.
     * @path /users/{userId}
     * @allow (create) User with matching ID can create their profile.
     * @allow (get) Any authenticated user can read any user profile.
     * @deny (create) User tries to create a profile with an ID that doesn't match their own.
     * @deny (update) User tries to update another user's profile.
     * @principle Enforces document ownership for writes and allows public reads.
     */
    match /users/{userId} {
      allow get: if true;
      allow list: if false;

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for user login data.
     * @path /users/{userId}/logins/{loginId}
     * @allow (create) User with matching ID can create their login data.
     * @deny (create) User tries to create login data with an ID that doesn't match their own.
     * @deny (update) User tries to update another user's login data.
     * @principle Enforces document ownership for writes and restricts access to a user's own login data.
     */
    match /users/{userId}/logins/{loginId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for user signup data.
     * @path /users/{userId}/signups/{signupId}
     * @allow (create) User with matching ID can create their signup data.
     * @deny (create) User tries to create signup data with an ID that doesn't match their own.
     * @deny (update) User tries to update another user's signup data.
     * @principle Enforces document ownership for writes and restricts access to a user's own signup data.
     */
    match /users/{userId}/signups/{signupId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for admin role assignment.
     * @path /roles_admin/{userId}
     * @allow (create) Only an admin can grant admin privileges.
     * @deny (create) Non-admin users cannot grant admin privileges.
     * @deny (update) No updates allowed after creation.
     * @principle Restricts admin role assignment to existing administrators.
     */
    match /roles_admin/{userId} {
      allow get: if isAdmin();
      allow list: if false;

      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}