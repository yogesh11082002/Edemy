/**
 * @fileoverview Firestore Security Rules for LearnVerse LMS.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, logins, and signups.
 * Administrative privileges are granted based on the existence of a document in the `roles_admin` collection.
 * Authorization Independence is a key principle, avoiding complex `get()` calls by denormalizing role information and relying on path-based ownership.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information; owned only by the user.
 * - /users/{userId}/logins/{loginId}: Stores login history; owned only by the user.
 * - /users/{userId}/signups/{signupId}: Stores signup information; owned only by the user.
 * - /roles_admin/{userId}: Indicates administrative privileges.
 *
 * Key Security Decisions:
 * - User listing is disallowed for the `/users` collection to protect privacy.
 * - Only the user or an admin can read/write their own profile, login, or signup data.
 * - The existence of a document in `/roles_admin/{userId}` grants full administrative privileges.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure user profiles, accessible only by the user or an admin.
     * @path /users/{userId}
     * @allow (create) - User with matching UID can create their profile.
     * @allow (get, update, delete) - User with matching UID or an admin can access and modify their profile.
     * @deny (list) - Listing all users is not allowed.
     * @deny (create) - User cannot create a profile with a different UID.
     * @principle Enforces document ownership for writes and restricts access to a user's own data.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isAdmin() {
        return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    /**
     * @description Secure user login information, accessible only by the user or an admin.
     * @path /users/{userId}/logins/{loginId}
     * @allow (create) - User with matching UID can create login entry.
     * @allow (get, update, delete) - User with matching UID or an admin can access and modify their login entries.
     * @allow (list) - User with matching UID or an admin can list their login entries.
     * @deny (create) - User cannot create a login entry with a different UID.
     * @principle Enforces document ownership for writes and restricts access to a user's own data.
     */
    match /users/{userId}/logins/{loginId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isAdmin() {
        return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    /**
     * @description Secure user signup information, accessible only by the user or an admin.
     * @path /users/{userId}/signups/{signupId}
     * @allow (create) - User with matching UID can create signup entry.
     * @allow (get, update, delete) - User with matching UID or an admin can access and modify their signup entries.
     * @allow (list) - User with matching UID or an admin can list their signup entries.
     * @deny (create) - User cannot create a signup entry with a different UID.
     * @principle Enforces document ownership for writes and restricts access to a user's own data.
     */
    match /users/{userId}/signups/{signupId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isAdmin() {
        return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

     /**
      * @description Secure admin roles, accessible only by admins.
      * @path /roles_admin/{userId}
      * @allow (create) - Any authenticated user can create their admin role. This should ideally be restricted via a backend function.
      * @allow (get) -  Any authenticated user can get an admin role (for checking access).
      * @allow (list) - Listing admin roles is not allowed for security reasons.
      * @allow (update, delete) - Only the admin themselves can update or delete their admin role (or another admin).
      * @principle Roles-based access control.
      */
    match /roles_admin/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isAdmin() {
        return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isExistingOwner(userId) || isAdmin();
    }
  }
}