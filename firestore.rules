/**
 * @fileoverview Firestore Security Rules for LearnVerse LMS.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles, logins, and signup data.
 * Administrative privileges are managed through a separate `roles_admin` collection.
 * Authorization Independence is achieved primarily through path-based ownership.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, secured by owner-only access.
 * - /users/{userId}/logins/{loginId}: Stores login information, accessible only by the user.
 * - /users/{userId}/signups/{signupId}: Stores signup information, accessible only by the user.
 * - /roles_admin/{userId}: Indicates admin privileges, checked via document existence.
 *
 * Key Security Decisions:
 * - User listing is disallowed for privacy.
 * - All write operations require authentication.
 * - No schema validation is enforced in this prototyping phase beyond relational integrity.
 * - Uses structural segregation to maintain a homogeneous security posture within each collection.
 *
 * Denormalization for Authorization:
 * - User roles are stored in the `/users/{userId}` document itself (denormalized), allowing for rules
 *   to check roles without additional `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secure user profile data. Only the user can read or write their own profile.
     * @path /users/{userId}
     * @allow (create) - Authenticated user creates their own profile with matching userId.
     * @allow (get, update, delete) - Authenticated user with matching userId.
     * @deny (create) - Unauthenticated user tries to create a profile.
     * @deny (create) - Authenticated user tries to create a profile with a mismatched userId.
     * @deny (get, update, delete) - Authenticated user tries to access another user's profile.
     * @principle Enforces document ownership for reads and writes.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secure user login data. Only the user can read or write their own login data.
     * @path /users/{userId}/logins/{loginId}
     * @allow (create) - Authenticated user creates their own login with matching userId.
     * @allow (get, update, delete) - Authenticated user with matching userId.
     * @deny (create) - Unauthenticated user tries to create a login.
     * @deny (create) - Authenticated user tries to create a login with a mismatched userId.
     * @deny (get, update, delete) - Authenticated user tries to access another user's login.
     * @principle Enforces document ownership for reads and writes.
     */
    match /users/{userId}/logins/{loginId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

       function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }


      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secure user signup data. Only the user can read or write their own signup data.
     * @path /users/{userId}/signups/{signupId}
     * @allow (create) - Authenticated user creates their own signup with matching userId.
     * @allow (get, update, delete) - Authenticated user with matching userId.
     * @deny (create) - Unauthenticated user tries to create a signup.
     * @deny (create) - Authenticated user tries to create a signup with a mismatched userId.
     * @deny (get, update, delete) - Authenticated user tries to access another user's signup.
     * @principle Enforces document ownership for reads and writes.
     */
    match /users/{userId}/signups/{signupId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Secure admin role data. Only admins (determined by document existence in this collection) can create, update, or delete.
     * @path /roles_admin/{userId}
     * @allow (create) - Authenticated admin user creates an admin role entry.
     * @allow (get, update, delete) - Authenticated admin user accesses admin role entry.
     * @deny (create, get, update, delete) - Non-admin user tries to access/modify admin role entry.
     *  @principle Restricts admin role management to existing admins.
     */
    match /roles_admin/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

     function isAdmin() {
        return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      }

      allow get: if isAdmin();
      allow list: if false;
      allow create: if isAdmin();
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }
  }
}